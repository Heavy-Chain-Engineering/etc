{
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "./.venv",
        "./dist",
        "./build",
        "./node_modules",
        "./.pytest_cache",
        "./.mypy_cache",
        "./.ruff_cache",
        "./.next",
        "./.turbo",
        "./.eslintcache",
        "./.tsbuildinfo",
        "./coverage",
        "./storybook-static"
      ],
      "denyRead": [
        "./.env",
        "./.env.local",
        "./.env.production"
      ]
    },
    "network": {
      "allowedHosts": [
        "*"
      ]
    }
  }
}
